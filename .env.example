# Server-side Secrets (Excluded from client bundle by default)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
LINKEDIN_CLIENT_ID="YOUR_LINKEDIN_CLIENT_ID_HERE"
LINKEDIN_CLIENT_SECRET="YOUR_LINKEDIN_CLIENT_SECRET_HERE"

# Client-side Public configuration
# (Prefixed with VITE_ to make them safely accessible to the React app in Vite)
VITE_FIREBASE_API_KEY="AIzaSy...YOUR_KEY_HERE"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID_HERE"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID_HERE"
VITE_FIREBASE_APP_ID="YOUR_APP_ID_HERE"
VITE_FIREBASE_DATABASE_ID="YOUR_FIRESTORE_DATABASE_ID_HERE"

# APP_URL: The URL where this applet is hosted.
APP_URL="YOUR_APP_HOSTING_URL"
